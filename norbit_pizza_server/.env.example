# App
NODE_ENV=development
PORT=3000

# App | Database
# For a host run use localhost. Docker-compose overrides DB_HOST to "db".
DB_HOST=localhost
DB_USER=norbit
DB_PASSWORD=change_me
DB_NAME=norbit_pizza
DB_CONNECTION_LIMIT=10

# App | Redis
# For a host run use localhost. Docker-compose overrides this to redis://redis:6379.
REDIS_URL=redis://localhost:6379
CACHE_ENABLED=true
CACHE_TTL_SECONDS=300
CACHE_PREFIX=norbit

# CORS ("*" allows all or a comma-separated allow-list)
CORS_ORIGIN=*

# Uploads (bytes, default 5 MiB)
MAX_UPLOAD_BYTES=5242880

# Rate limit
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
RATE_LIMIT_WRITE_MAX=30

TRUST_PROXY=false

# Admin auth (optional)
# If set POST/PUT/DELETE on products and images require header: X-API-Key: <key>
# Leave empty to keep the endpoints open (original behaviour)
ADMIN_API_KEY=

# docker-compose: MySQL container bootstrap ---
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=norbit_pizza
MYSQL_USER=norbit
MYSQL_PASSWORD=change_me
