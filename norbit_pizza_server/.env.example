DB_HOST=db
DB_USER=norbit
DB_PASSWORD=norbitpassword
DB_NAME=norbit_pizza
PORT=3000

# MySQL root password used in docker-compose
MYSQL_ROOT_PASSWORD=rootpassword

### Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=norbit_pizza
PORT=3000

### MinIO (S3-compatible) - optional for object storage
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=images

### Storage mode: one of blob|fs|s3
# blob - store images as BLOBs in DB (current code)
# fs   - store images on local filesystem (not implemented)
# s3   - store images in S3/MinIO (not implemented)
STORAGE=blob
